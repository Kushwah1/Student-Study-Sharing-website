# ============================================
# Environment Configuration
# Copy this file to .env and update values
# ============================================

# Server Port (Render sets this automatically)
PORT=5000

# MongoDB Connection String
# For local: mongodb://localhost:27017/student_notes_db
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/student_notes_db
MONGODB_URI=mongodb://localhost:27017/student_notes_db

# JWT Secret Key (change to a random secure string in production)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# JWT Token Expiry
JWT_EXPIRE=7d

# Max File Upload Size (in bytes) - 10MB
MAX_FILE_SIZE=10485760
